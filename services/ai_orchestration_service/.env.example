LLM_PROVIDER=local
# Optional: leave these blank or provide keys if switching providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_API_KEY=
# When running a local LLM container on the same network, use its service name.
LOCAL_LLM_URL=http://local-llm:1234/v1/chat/completions
LLM_TIMEOUT=10.0
