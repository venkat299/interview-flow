LLM_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
GEMINI_API_KEY=
LOCAL_LLM_URL=http://host.docker.internal:1234/v1/chat/completions

# Logging / tracing
# Set to TRACE for maximal verbosity
LOG_LEVEL=TRACE
# Set to true/1 to log function CALL/RETURN across service modules
TRACE_CALLS=true
# Comma-separated module prefixes to trace (e.g., api_service,orchestrator_service)
TRACE_MODULE_PREFIXES=
# Comma-separated path substrings; any file path containing one will be traced
# Defaults to tracing files under the repo's services directory
TRACE_FILE_PATH_CONTAINS=services/
# If true, print concise trace logs (no timestamp/level prefix)
TRACE_CONCISE=true
